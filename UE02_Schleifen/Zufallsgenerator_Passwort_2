namespace ZufallsGenerator_2
{
    internal class Program
    {
        static void Main()
        {
            Random random = new Random();
            string password = "";

            for (int i = 0; i < 10; i++)
            {
                int asciiWert = random.Next(33, 127);
                password += ((char)asciiWert).ToString();
            }
            Console.WriteLine($"Your generated password is: {password}");
        }
    }
}
