/* erstellen Sie eine Anwendung, welche den Bediener nach der Eingabe einer Zahl fragt Solange die eingegeben Zahl kleiner 
 * als 10 st, soll das Programm eine Fehlermeldung ausgeben und wieder zur Eingabe auffordern. 
 * Wird die Zahl >= 10 eingegeben, soll das programm beendet werden. 
 */
namespace Übung_3
{
    internal class Program
    {
        static void Main()
        {
            int zahl = 0; // Startwert der Variable

            while (zahl < 10)
            {
                Console.WriteLine("Bitte geben Sie eine Zahl ein: ");
                zahl = Convert.ToInt32(Console.ReadLine());

                if (zahl < 10)
                {
                    Console.WriteLine("Error: Die Zahl ist kleiner als 10. Bitte erneut versuchen.\n");
                }
            }

            Console.WriteLine("Programm beendet, da eine Zahl größer als 10 eingegeben wurde.");
        }
    }
}
