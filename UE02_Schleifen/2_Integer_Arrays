/*
 * Erstellen Sie zwei Integer-Arrays mit den Werten 2,3,5,7,11 
 * und Werten 1,3, 7, 9. Durchlaufen Sie beide Arrays in geeigneten Schleifen. 
 * Werte, die in beiden Arrays gleich sind geben Sie in der Konsole aus.
*/

namespace Arrays_Schleifen
{
    internal class Program
    {
        static void Main()
        {
            int[] Array_1 = { 2, 3, 5, 7, 11 };
            int[] Array_2 = { 1, 3, 7, 9 };

            // Zwei Variablen für die beiden Treffer vorbereiten
            int a = 0;
            int b = 0;

            foreach (int i in Array_1)
            {
                foreach (int j in Array_2)
                {
                    if (i == j)
                    {
                        if (a == 0) // Wenn 'a' noch leer ist, fülle 'a'. Ansonsten fülle 'b'.
                        {
                            a = i;
                        }
                        else
                        {
                            b = j;
                        }
                        break;
                    }
                }
            }
            Console.WriteLine($"gleiche Werte sind a:{a} und b:{b}");
        }
    }
}
