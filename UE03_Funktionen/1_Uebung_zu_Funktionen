namespace Uebung_zu_Funktionen
{
    internal class Program
    {
        static void Main()
        {
            string[] p = { "Datei", "Bearbeiten ", "Impressum " };
            string[] Eingabe = Menu(p);

        }
        static string[] Menu(string[] p)
        {
            string[] Eingabe = new string[p.Length];

            for (int i = 0; i < p.Length; i++)
            {
                Console.WriteLine(p[i]);
                Eingabe[i] = Console.ReadLine();
            }
            return Eingabe;
        }
    }
}