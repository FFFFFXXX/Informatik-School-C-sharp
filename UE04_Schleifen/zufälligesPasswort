namespace ZufallsGenerator_3
{
	internal class Program
	{
		static void Main()
		{
			Console.Write("Wie viele Zeichen soll dein zufällig generiertes Passwort enthalten? Anzahl: "); // Input User
			//int anzahl = Convert.ToInt32(Console.ReadLine()); //Convert Input User to int
			int anzahl = int.Parse(Console.ReadLine());
			
			Random random = new Random();
            string password = "";

            do
            {
                for (int i = 0; i < 10; i++)
                {
                int generiert = random.Next(33, 127);
                password += ((char)generiert).ToString();
                }
            } while (anzahl < 10);

            Console.WriteLine($"Your generated password is: {password}");
         }
     }
}
