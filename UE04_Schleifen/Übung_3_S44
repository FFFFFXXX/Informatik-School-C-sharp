/*
* Erstellen Sie eine Anwendung, welche den Bediener nach der Eingabe einer Zahl fragt. Solange die eingegebene Zahl kleiner 10 is, soll das Programm eine Fehlermeldung ausgeben
* und wieder zur Eingabe einer neuen Zahl auffordern. WIrd eine Zahl >= 10 eingegeben, soll das Programm beendet werden. Wir gehen davon aus, dass ausschließlich Zahlenwerte 
* eingegeben werden.
*/

namespace Übung_3
{
    internal class Program
    {
        static void Main()
        {
            int zahl = 0; // Startwert der Variable

            while (zahl < 10)
            {
                Console.WriteLine("Bitte geben Sie eine Zahl ein: ");
                zahl = Convert.ToInt32(Console.ReadLine());

                if (zahl < 10)
                {
                    Console.WriteLine("Error: Die Zahl ist kleiner als 10. Bitte erneut versuchen.\n");
                }
            }

            Console.WriteLine("Programm beendet, da eine Zahl größer als 10 eingegeben wurde.");
        }
    }
}
