
/*Schreiben Sie eine Anwendung, um den Bestellvorgang an einem Getränkeautomat abzubilde. Der Automat verkauft
* Wasserflaschen im Wert von 1,50 Euro.
* 
* Folgende Logik: 
* 1.Der Benutzer muss die Anzahl der flaschen angeben, die er kaufen möchte
* mehr als 10 Flaschen können nicht gekauft werden
* eine fehlerhafte Eingabe führt zu einer Fehlermeldung und zur erneuten Abfrage der anzahl
* war die Eingabe korrekt, wird der Gesamtpreis der Bestellung berechnet und ausgegeben
* *
* 2. Ist eine Bestellung abgeschlossen, soll der Benutzer gefragt werden, ob er eine weitere Bestellung aufgeben möchte
* die möglichen Einhaben sind hier "j" oder "n"
* bei "j" beginnt der Prozess neu
* "n" beendet das Programm
* alle anderen Eingaben führen zu einer Fehlermeldung und dem erneuten Abfragen, ob eine weitere Bestellung ausgeführt werden soll
*/


namespace Bestellvorgang_Getränke
{
    internal class Program
    {
        static void Main()
        {
            int Flaschenanzahl = 0;
            bool Abfrage = true;

            while (Abfrage)
            {
                bool Eingabe = false;

                while (!Eingabe)
                {
                    Console.WriteLine("Geben sie eine Anzahl der Flaschen ein, die Sie kaufen möchten: \n");
                    Flaschenanzahl = Convert.ToInt32(Console.ReadLine());

                    if (Flaschenanzahl > 10 || Flaschenanzahl <= 0)
                    {
                        Console.WriteLine("Mehr als 10 Flaschen können nicht auf einmal bestellt werden. Bitte versuchen Sie es erneut.");
                    }
                    else
                    {
                        Eingabe = true;
                    }
                }
                double Preis = Flaschenanzahl * 1.5;
                Console.WriteLine("Der Preis für {Flaschenanzahl} beträgt" + Preis + "Euro.");

                // Abfrage für eine weitere Bestellung
                bool weitereBestellung = false;
                while (!weitereBestellung)
                {
                    Console.WriteLine("\nMöchten Sie eine weitere Bestellung aufgeben? (j/n):");
                    string antwort = Console.ReadLine();

                    if (antwort == "j")
                    {
                        weitereBestellung = true; // Verlässt diese Schleife, äußere Schleife startet neu
                    }
                    else if (antwort == "n")
                    {
                        weitereBestellung = true;
                        Abfrage = false; // Beendet das gesamte Programm
                        Console.WriteLine("Programm beendet. Auf Wiedersehen!");
                    }
                    else
                    {
                        Console.WriteLine("Fehlerhafte Eingabe! Bitte geben Sie nur 'j' oder 'n' ein.");
                    }
                }
            }
        }
    }
}
